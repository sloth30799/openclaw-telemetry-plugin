# Full receiver URL. The default path targets the app event API.
MISSION_CONTROL_RECEIVER_ENDPOINT=http://localhost:3000/api/openclaw/plugin/events

# Optional shared write token. If unset, the plugin sends no token header.
# Set this for hosted or shared environments. Never commit the real token.
# MISSION_CONTROL_PLUGIN_TOKEN=local-telemetry-bridge-token-placeholder

# Optional Vercel Protection Bypass for Automation token, if your receiver is
# behind Vercel Deployment Protection.
# Prefer the x-vercel-protection-bypass header path; avoid putting this in URLs.
# MISSION_CONTROL_VERCEL_BYPASS_TOKEN=optional-vercel-bypass-token-placeholder
